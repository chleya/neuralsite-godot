# NeuralSite环境配置示例
# 复制此文件为.env并修改配置

# 应用配置
APP_NAME=NeuralSite
APP_VERSION=1.0.0
DEBUG=true

# 数据库配置
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/neuralsite
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=your_password

# CORS配置
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000","http://localhost:5173","http://127.0.0.1:5173"]

# 认证配置
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 区块链配置（可选）
BLOCKCHAIN_ENABLED=false
# BLOCKCHAIN_NODE_URL=https://your-chain-node-url

# 文件存储配置
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# 空间计算配置
COORDINATE_SYSTEM=CGCS2000
DEFAULT_LATERAL_OFFSET=0.0
SPATIAL_INDEX_TYPE=rtree
